# ─────────────────────────────────────────────
# APP
# ─────────────────────────────────────────────
# URL base de la aplicación (sin slash final)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─────────────────────────────────────────────
# STRIPE
# ─────────────────────────────────────────────
# Clave secreta de Stripe (sk_test_... en desarrollo, sk_live_... en producción)
STRIPE_SECRET_KEY=sk_test_REEMPLAZAR_CON_TU_CLAVE

# Secreto del webhook de Stripe (se obtiene con `stripe listen` o en el dashboard)
STRIPE_WEBHOOK_SECRET=whsec_REEMPLAZAR_CON_TU_SECRETO

# ─────────────────────────────────────────────
# GOOGLE SHEETS
# ─────────────────────────────────────────────
# Email de la cuenta de servicio (Service Account)
GOOGLE_SHEETS_CLIENT_EMAIL=verde@tuproyecto.iam.gserviceaccount.com

# Clave privada de la cuenta de servicio
# En Vercel: pegar el valor completo incluyendo los saltos de línea como \n
# Ejemplo: "-----BEGIN PRIVATE KEY-----\nMIIEvgIBAD...\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEETS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nREEMPLAZAR\n-----END PRIVATE KEY-----\n"

# ID de la hoja de cálculo (el string largo en la URL de Google Sheets)
# Ejemplo: https://docs.google.com/spreadsheets/d/ESTE_ES_EL_ID/edit
GOOGLE_SHEETS_SPREADSHEET_ID=REEMPLAZAR_CON_EL_ID

# ─────────────────────────────────────────────
# RESEND (emails)
# ─────────────────────────────────────────────
RESEND_API_KEY=re_REEMPLAZAR_CON_TU_API_KEY

# Email desde el que se envían los correos (debe estar verificado en Resend)
VERDE_FROM_EMAIL=verde@tudominio.com

# Email del equipo Verde que recibirá los pedidos y alertas
VERDE_INTERNAL_EMAIL=equipo@tudominio.com
